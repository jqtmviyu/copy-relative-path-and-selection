{
  "name": "copy-relative-path-and-line-numbers",
  "displayName": "Copy: Selection and Relative Selection",
  "description": "Copy selected code as AI-ready context with absolute or relative paths. Supports multi-cursor and multi-file selections.",
  "version": "0.0.3",
  "publisher": "jqtmviyu",
  "repository": {},
  "icon": "images/icon.png",
  "extensionKind": [
    "workspace"
  ],
  "engines": {
    "vscode": "^1.51.0"
  },
  "keywords": [
    "copy",
    "file path",
    "line number",
    "clipboard"
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:copy-relative-path-and-line-numbers.absolute-selection",
    "onCommand:copy-relative-path-and-line-numbers.relative-selection"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copy-relative-path-and-line-numbers.absolute-selection",
        "title": "Copy: Selection"
      },
      {
        "command": "copy-relative-path-and-line-numbers.relative-selection",
        "title": "Copy: Selection (Relative)"
      }
    ],
    "menus": {
      "editor/title/context": [
        {
          "command": "copy-relative-path-and-line-numbers.absolute-selection"
        },
        {
          "command": "copy-relative-path-and-line-numbers.relative-selection"
        }
      ],
      "editor/context": [
        {
          "command": "copy-relative-path-and-line-numbers.absolute-selection"
        },
        {
          "command": "copy-relative-path-and-line-numbers.relative-selection"
        }
      ]
    }
  },
  "scripts": {
    "postinstall": "node ./node_modules/vscode/bin/install",
    "test": "node ./node_modules/vscode/bin/test"
  },
  "devDependencies": {
    "typescript": "^2.6.1",
    "vscode": "^1.1.6",
    "eslint": "^4.11.0",
    "@types/node": "^7.0.43",
    "@types/mocha": "^2.2.42"
  },
  "dependencies": {}
}
